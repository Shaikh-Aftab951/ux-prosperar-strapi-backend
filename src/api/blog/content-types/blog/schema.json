{
  "kind": "collectionType",
  "collectionName": "blogs",
  "info": {
    "singularName": "blog",
    "pluralName": "blogs",
    "displayName": "Blog"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "Title": {
      "type": "string",
      "maxLength": 200,
      "required": true
    },
    "Slug": {
      "type": "uid",
      "targetField": "Title",
      "required": true
    },
    "Content": {
      "type": "richtext",
      "required": true
    },
    "ReadTime": {
      "type": "string",
      "default": "3 MINUTE READ",
      "required": true
    },
    "Featured": {
      "type": "boolean",
      "default": false
    },
    "PublishDate": {
      "type": "string"
    },
    "CardImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "HeroImage": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    }
  }
}
